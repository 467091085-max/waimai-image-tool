# Copy this file to .env.cos on your Mac, then fill in the real values.
# .env.cos is ignored by git and must never be committed.

TENCENTCLOUD_SECRET_ID=你的腾讯云 SecretId
TENCENTCLOUD_SECRET_KEY=你的腾讯云 SecretKey
TENCENT_COS_BUCKET=waimai-image-tool-inputs-1311836560
TENCENT_COS_REGION=ap-guangzhou
TENCENTCLOUD_REGION=ap-guangzhou

# Optional. The default gallery prefix is waimai-gallery.
# TENCENT_COS_PREFIX=waimai-gallery
